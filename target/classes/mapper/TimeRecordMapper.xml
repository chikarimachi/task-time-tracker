<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="ru.test.tasktracker.mapper.TimeRecordMapper">

    <resultMap id="TimeRecordResultMap" type="ru.test.tasktracker.model.TimeRecord">
        <id property="id" column="id"/>
        <result property="employeeId" column="employee_id"/>
        <result property="taskId" column="task_id"/>
        <result property="startTime" column="start_time"/>
        <result property="endTime" column="end_time"/>
        <result property="workDescription" column="work_description"/>
    </resultMap>

    <insert id="insert" parameterType="ru.test.tasktracker.model.TimeRecord" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO time_records(employee_id, task_id, start_time, end_time, work_description)
        VALUES (#{employeeId}, #{taskId}, #{startTime}, #{endTime}, #{workDescription})
    </insert>

    <select id="findByEmployeeAndPeriod" resultMap="TimeRecordResultMap">
        SELECT id, employee_id, task_id, start_time, end_time, work_description
        FROM time_records
        WHERE employee_id = #{employeeId}
            AND start_time &gt;= #{from}
            AND end_time &lt;= #{to}
        ORDER BY start_time
    </select>

</mapper>
