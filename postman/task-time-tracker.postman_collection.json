          "raw": "{\n  \"employeeId\": 1001,\n  \"taskId\": 1,\n  \"startTime\": \"2026-04-20T10:00:00\",\n  \"endTime\": \"2026-04-20T12:30:00\",\n  \"workDescription\": \"Проработка архитектуры\"\n}"
